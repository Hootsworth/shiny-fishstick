# Shiny Fishstick Environment Variables

# SQLite default database path, switchable to postgresql
DATABASE_URL=sqlite:///./preflight.db

# Symmetric database credentials encryption key
# Must be a 32-byte URL-safe base64 key
# Generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SHINY_FISHSTICK_ENCRYPTION_KEY=

# Task Queue Broker URL
REDIS_URL=redis://localhost:6379/0

# Optional Gemini AI API configuration key
GEMINI_API_KEY=

# Optional Ollama offline inference configurations
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=
